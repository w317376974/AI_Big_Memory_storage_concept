4.5 媒体特征提取 (完整版)
import subprocess
import json
import os
import tempfile
from typing import List, Optional, Dict
from PIL import Image


class MediaFeatureExtractor:
    """媒体特征提取器 - 视频/音频/图片"""
    
    def __init__(self, ffprobe_path: str = "ffprobe", ffmpeg_path: str = "ffmpeg"):
        self.ffprobe_cmd = ffprobe_path
        self.ffmpeg_cmd = ffmpeg_path
    
    def extract(self, file_path: str) -> Dict:
        """提取媒体特征"""
        
        media_type = self._detect_media_type(file_path)
        
        if media_type == "video":
            return self._extract_video_features(file_path)
        elif media_type == "audio":
            return self._extract_audio_features(file_path)
        elif media_type == "image":
            return self._extract_image_features(file_path)
        else:
            return {}
    
    def _detect_media_type(self, file_path: str) -> str:
        """检测媒体类型"""
        
        ext = os.path.splitext(file_path)[1].lower()
        
        video_exts = ['.mp4', '.mkv', '.avi', '.mov', '.wmv', '.flv', '.webm', '.m4v']
        audio_exts = ['.mp3', '.wav', '.flac', '.aac', '.ogg', '.m4a', '.wma']
        image_exts = ['.jpg', '.jpeg', '.png', '.gif', '.bmp', '.webp', '.tiff']
        
        if ext in video_exts:
            return "video"
        elif ext in audio_exts:
            return "audio"
        elif ext in image_exts:
            return "image"
        
        return "unknown"
    
    def _extract_video_features(self, file_path: str) -> Dict:
        """提取视频特征"""
        
        cmd = [
            self.ffprobe_cmd, "-v", "quiet", "-print_format", "json",
            "-show_format", "-show_streams", "-i", file_path
        ]
        
        try:
            result = subprocess.check_output(cmd, stderr=subprocess.STDOUT)
            data = json.loads(result)
        except (subprocess.CalledProcessError, json.JSONDecodeError):
            return {}
        
        features = {}
        
        # 视频流信息
        video_stream = next((
            s for s in data.get('streams', []) 
            if s.get('codec_type') == 'video'
        ), None)
        
        if video_stream:
            fps_str = video_stream.get('r_frame_rate', '0/1')
            fps = eval(fps_str) if '/' in fps_str else float(fps_str)
            
            features.update({
                'width': video_stream.get('width', 0),
                'height': video_stream.get('height', 0),
                'resolution': f"{video_stream.get('width', 0)}x{video_stream.get('height', 0)}",
                'codec': video_stream.get('codec_name'),
                'fps': round(fps, 2),
                'bitrate': int(video_stream.get('bit_rate', 0)),
                'pix_fmt': video_stream.get('pix_fmt')
            })
        
        # 音频流信息
        audio_stream = next((
            s for s in data.get('streams', []) 
            if s.get('codec_type') == 'audio'
        ), None)
        
        if audio_stream:
            features.update({
                'audio_codec': audio_stream.get('codec_name'),
                'audio_bitrate': int(audio_stream.get('bit_rate', 0)),
                'sample_rate': int(audio_stream.get('sample_rate', 0)),
                'channels': audio_stream.get('channels')
            })
        
        # 格式信息
        format_info = data.get('format', {})
        features.update({
            'duration': float(format_info.get('duration', 0)),
            'duration_display': self._format_duration(float(format_info.get('duration', 0))),
            'file_size': int(format_info.get('size', 0)),
            'file_size_display': self._format_size(int(format_info.get('size', 0))),
            'format_name': format_info.get('format_name'),
            'bit_rate': int(format_info.get('bit_rate', 0))
        })
        
        features['quality_label'] = self._estimate_quality_label(
            features.get('width', 0), features.get('height', 0), features.get('bit_rate', 0)
        )
        
        return features
    
    def _extract_audio_features(self, file_path: str) -> Dict:
        """提取音频特征"""
        
        cmd = [self.ffprobe_cmd, "-v", "quiet", "-print_format", "json",
               "-show_format", "-show_streams", "-i", file_path]
        
        try:
            result = subprocess.check_output(cmd, stderr=subprocess.STDOUT)
            data = json.loads(result)
        except:
            return {}
        
        features = {}
        
        audio_stream = next((s for s in data.get('streams', []) if s.get('codec_type') == 'audio'), None)
        
        if audio_stream:
            features.update({
                'codec': audio_stream.get('codec_name'),
                'sample_rate': int(audio_stream.get('sample_rate', 0)),
                'channels': audio_stream.get('channels'),
                'bitrate': int(audio_stream.get('bit_rate', 0))
            })
        
        format_info = data.get('format', {})
        features.update({
            'duration': float(format_info.get('duration', 0)),
            'duration_display': self._format_duration(float(format_info.get('duration', 0))),
            'file_size': int(format_info.get('size', 0)),
            'file_size_display': self._format_size(int(format_info.get('size', 0))),
            'format': format_info.get('format_name')
        })
        
        return features
    
    def _extract_image_features(self, file_path: str) -> Dict:
        """提取图片特征"""
        
        features = {}
        
        try:
            with Image.open(file_path) as img:
                features.update({
                    'width': img.width,
                    'height': img.height,
                    'resolution': f"{img.width}x{img.height}",
                    'format': img.format,
                    'mode': img.mode,
                    'file_size': os.path.getsize(file_path),
                    'file_size_display': self._format_size(os.path.getsize(file_path))
                })
                
                if img.mode == 'RGBA':
                    features['color_type'] = 'RGBA (带透明)'
                elif img.mode == 'L':
                    features['color_type'] = '灰度'
                else:
                    features['color_type'] = 'RGB'
        except:
            pass
        
        return features
    
    def extract_keyframes(self, file_path: str, interval: int = 300, max_frames: int = 10) -> List[str]:
        """提取关键帧 (用于向量生成)"""
        
        features = self._extract_video_features(file_path)
        duration = features.get('duration', 0)
        
        if duration == 0:
            return []
        
        num_frames = min(max_frames, max(1, int(duration / interval)))
        interval = duration / num_frames
        
        keyframes = []
        
        with tempfile.TemporaryDirectory() as tmpdir:
            for i in range(num_frames):
                t = interval * i
                output_path = os.path.join(tmpdir, f"frame_{i:03d}.jpg")
                
                cmd = [self.ffmpeg_cmd, "-ss", str(t), "-i", file_path,
                       "-vframes", "1", "-q:v", "2", "-y", output_path]
                
                try:
                    subprocess.run(cmd, check=True, capture_output=True)
                    if os.path.exists(output_path) and os.path.getsize(output_path) > 0:
                        keyframes.append(output_path)
                except:
                    continue
        
        return keyframes
    
    def _format_duration(self, seconds: float) -> str:
        """格式化时长"""
        
        if seconds < 60:
            return f"{int(seconds)}秒"
        elif seconds < 3600:
            return f"{int(seconds // 60)}分{int(seconds % 60)}秒"
        else:
            return f"{int(seconds // 3600)}小时{int((seconds % 3600) // 60)}分"
    
    def _format_size(self, bytes_size: int) -> str:
        """格式化文件大小"""
        
        for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
            if bytes_size < 1024:
                return f"{bytes_size:.2f} {unit}"
            bytes_size /= 1024
        return f"{bytes_size:.2f} PB"
    
    def _estimate_quality_label(self, width: int, height: int, bitrate: int) -> str:
        """估算视频质量标签"""
        
        pixels = width * height
        
        if pixels >= 8294400:
            return "4K"
        elif pixels >= 2073600:
            return "1080P" if bitrate > 3000000 else "1080P 标准"
        elif pixels >= 921600:
            return "720P"
        elif pixels >= 480000:
            return "标清"
        else:
            return "低清"


