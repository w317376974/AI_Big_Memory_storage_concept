import json
import re
import os
from typing import Dict, List, Optional


class LLMMetadataExtractor:
    """基于 LLM 的语义元数据提取"""
    
    SYSTEM_PROMPT = """你是一个专业的元数据提取助手。
根据用户描述的信息，提取结构化的元数据。

请严格按照JSON格式返回，不要有其他内容。
可用字段:
- title: 标题/名称 (string)
- category: 分类 (可选: movie/video/document/image/audio/code/other)
- tags: 关键词标签数组
- location_name: 地名,如果有
- description: 简短描述,不超过50字
- related_entities: 相关的实体,如人名、作品名等
- implied_intent: 隐含意图 (store/watch/use/share/review)

如果某字段无法提取,请使用null。"""
    
    def __init__(self, llm_client):
        self.llm = llm_client
    
    async def extract(self, user_description: str, filename: str = None) -> Dict:
        """提取语义元数据"""
        
        input_text = user_description
        if filename:
            input_text += f"\n\n文件名: {filename}"
        
        try:
            response = await self.llm.chat(system=self.SYSTEM_PROMPT, user=input_text)
            metadata = self._parse_json_response(response)
        except:
            metadata = {}
        
        # 从文件名补充信息
        if filename and not metadata.get('title'):
            metadata['title'] = os.path.splitext(filename)[0]
        
        if filename and not metadata.get('category'):
            metadata['category'] = self._infer_category_from_filename(filename)
        
        return metadata
    
    def _parse_json_response(self, response: str) -> Dict:
        """解析 LLM 返回的 JSON"""
        
        try:
            return json.loads(response)
        except json.JSONDecodeError:
            match = re.search(r'\{[^{}]*\}', response, re.DOTALL)
            if match:
                try:
                    return json.loads(match.group())
                except:
                    pass
        return {}
    
    def _infer_category_from_filename(self, filename: str) -> Optional[str]:
        """从文件名推断分类"""
        
        ext = os.path.splitext(filename)[1].lower()
        
        video_exts = ['.mp4', '.mkv', '.avi', '.mov']
        audio_exts = ['.mp3', '.wav', '.flac', '.aac']
        image_exts = ['.jpg', '.jpeg', '.png', '.gif']
        doc_exts = ['.pdf', '.doc', '.docx', '.txt']
        
        if ext in video_exts:
            return 'video'
        elif ext in audio_exts:
            return 'audio'
        elif ext in image_exts:
            return 'image'
        elif ext in doc_exts:
            return 'document'
        
        return None
    
    async def generate_summary(self, content: str, max_length: int = 200) -> str:
        """生成内容摘要"""
        
        prompt = f"请为以下内容生成一个{max_length}字以内的简洁摘要:\n\n{content[:5000]}\n\n摘要:"
        
        return await self.llm.chat(prompt=prompt)
    
    async def extract_tags_from_content(self, content: str) -> List[str]:
        """从内容中提取标签"""
        
        prompt = f"从以下内容中提取关键词标签 (5-10个):\n\n{content[:3000]}\n\n返回JSON数组:"
        
        try:
            response = await self.llm.chat(prompt=prompt)
            tags = json.loads(response)
            if isinstance(tags, list):
                return [str(t) for t in tags]
        except:
            pass
        
        return []
