### 6.6 文件生命周期管理

```python
class FileLifecycleManager:
    """文件生命周期管理"""
    
    def __init__(self, db_client, minio_client, storage_quota_gb: int = 100):
        self.db = db_client
        self.minio = minio_client
        self.quota = storage_quota_gb * 1024**3
    
    async def check_storage_quota(self) -> Dict:
        """检查存储配额"""
        
        total_size = await self.db.query("""
            SELECT COALESCE(SUM(file_size), 0) as total 
            FROM file_metadata
        """)
        
        used = total_size[0]['total']
        available = self.quota - used
        
        return {
            'quota_gb': self.quota / 1024**3,
            'used_gb': used / 1024**3,
            'available_gb': available / 1024**3,
            'usage_percent': (used / self.quota) * 100
        }
    
    async def find_duplicate_files(self) -> List[Dict]:
        """查找重复文件 (MD5 相同)"""
        
        duplicates = await self.db.query("""
            SELECT md5_hash, array_agg(id) as file_ids, 
                   array_agg(filename) as filenames,
                   COUNT(*) as count,
                   MAX(file_size) as file_size
            FROM file_metadata
            WHERE md5_hash IS NOT NULL
            GROUP BY md5_hash
            HAVING COUNT(*) > 1
        """)
        
        return duplicates
    
    async def cleanup_unlinked_files(self, days: int = 30) -> int:
        """清理未关联的记忆的孤立文件"""
        
        # 查找超过 days 天没有关联记忆的文件
        unlinked = await self.db.query("""
            SELECT id, filename, stored_path
            FROM file_metadata
            WHERE memory_id IS NULL
              AND created_at < NOW() - INTERVAL '%s days'
        """, days)
        
        deleted_count = 0
        for file in unlinked:
            # 从 MinIO 删除
            if file['stored_path']:
                await self.minio.delete_object(file['stored_path'])
            
            # 从数据库删除
            await self.db.delete_file(file['id'])
            deleted_count += 1
        
        return deleted_count
    
    async def archive_old_files(self, days: int = 365, archive_tier: str = 'cold'):
        """归档旧文件 (转移到冷存储)"""
        
        old_files = await self.db.query("""
            SELECT id, filename, stored_path
            FROM file_metadata
            WHERE created_at < NOW() - INTERVAL '%s days'
              AND storage_tier = 'hot'
        """, days)
        
        for file in old_files:
            # 移动到冷存储
            new_path = await self.minio.move_to_cold_storage(file['stored_path'])
            
            # 更新数据库
            await self.db.update_file(file['id'], {
                'stored_path': new_path,
                'storage_tier': 'cold',
                'archived_at': datetime.now()
            })
        
        return len(old_files)
