class MetadataPipeline:
    """完整元数据提取管道"""
    
    def __init__(self, llm_client, geocoding_client, embedding_service, 
                 media_extractor, minio_client, db_client, kafka_producer):
        self.llm = llm_client
        self.geo = geocoding_client
        self.embedding = embedding_service
        self.media = media_extractor
        self.minio = minio_client
        self.db = db_client
        self.kafka = kafka_producer
    
    async def process(self, file_path: str, user_description: str = "",
                      user_tags: list = None, project_id: str = None) -> Dict:
        """完整处理流程"""
        
        metadata = {}
        
        # Phase 1: 基础元数据
        basic = self._extract_basic(file_path)
        metadata.update(basic)
        
        # Phase 2: 语义提取 (LLM)
        semantic = await self._extract_semantic(user_description, metadata.get('filename'))
        metadata.update(semantic)
        
        if user_tags:
            metadata['user_tags'] = list(set(metadata.get('user_tags', []) + user_tags))
        
        # Phase 3: 媒体特征
        if self._is_media(file_path):
            media_features = self.media.extract(file_path)
            if media_features.get('file_size'):
                metadata['file_size'] = media_features['file_size']
            if media_features.get('duration'):
                metadata['duration'] = media_features['duration']
            metadata['media_features'] = media_features
        
        # Phase 4: 地理编码
        if metadata.get('location_name'):
            geo_result = await self.geo.geocode(metadata['location_name'])
            if geo_result:
                metadata.update({
                    'location': self.geo.to_postgis(geo_result['lat'], geo_result['lon']),
                    'location_lat': geo_result['lat'],
                    'location_lon': geo_result['lon']
                })
        
        # Phase 5: 哈希计算
        metadata['md5_hash'] = self._calculate_md5(file_path)
        
        # Phase 6: 向量生成
        text_for_embedding = f"{metadata.get('title', '')} {metadata.get('description', '')} {' '.join(metadata.get('user_tags', []))}"
        metadata['embedding'] = await self.embedding.encode(text_for_embedding)
        
        # Phase 7: 存储到 MinIO
        stored_path = await self._store_to_minio(file_path, metadata)
        metadata['stored_path'] = stored_path
        
        # Phase 8: 创建关联记忆
        memory_id = await self._create_memory(metadata, user_description)
        metadata['memory_id'] = memory_id
        
        # Phase 9: 写入数据库
        file_id = await self._save_to_db(metadata, project_id)
        metadata['id'] = file_id
        
        # Phase 10: 发送 Kafka 事件
        await self._publish_event('created', metadata)
        
        return metadata
    
    def _extract_basic(self, path: str) -> Dict:
        """基础元数据"""
        
        stat = os.stat(path)
        filename = os.path.basename(path)
        name, ext = os.path.splitext(filename)
        
        return {
            'filename': filename,
            'file_size': stat.st_size,
            'format': ext[1:].lower() if ext else None,
            'mime_type': self._get_mime_type(ext),
            'title': name,
            'created_at': datetime.now()
        }
    
    async def _extract_semantic(self, user_description: str, filename: str = None) -> Dict:
        """语义提取"""
        
        try:
            return await self.llm.extract(user_description or '', filename)
        except:
            return {'title': filename or 'Untitled', 'category': 'other', 'user_tags': []}
    
    def _is_media(self, path: str) -> bool:
        ext = os.path.splitext(path)[1].lower()
        return ext in ['.mp4', '.mkv', '.avi', '.mp3', '.wav', '.jpg', '.jpeg', '.png']
    
    def _calculate_md5(self, path: str) -> str:
        hash_md5 = hashlib.md5()
        with open(path, 'rb') as f:
            for chunk in iter(lambda: f.read(4096), b""):
                hash_md5.update(chunk)
        return hash_md5.hexdigest()
    
    async def _store_to_minio(self, file_path: str, metadata: Dict) -> str:
        bucket = "files"
        object_key = f"{datetime.now().strftime('%Y%m%d')}/{metadata['filename']}"
        
        await self.minio.ensure_bucket(bucket)
        await self.minio.upload_file(bucket, object_key, file_path)
        
        return f"minio://{bucket}/{object_key}"
    
    async def _create_memory(self, metadata: Dict, user_description: str) -> Optional[str]:
        content = f"保存了文件: {metadata['filename']}"
        if metadata.get('file_size'):
            content += f", 大小: {metadata['file_size']} 字节"
        
        memory_data = {
            'atom_type': 'raw_daily',
            'content': content,
            'tags': metadata.get('user_tags', []),
            'source_date': datetime.now().date()
        }
        
        return await self.db.create_memory(memory_data)
    
    async def _save_to_db(self, metadata: Dict, project_id: str) -> str:
        file_data = {
            'filename': metadata['filename'],
            'file_size': metadata['file_size'],
            'format': metadata['format'],
            'title': metadata.get('title'),
            'user_tags': metadata.get('user_tags', []),
            'embedding': metadata.get('embedding'),
            'stored_path': metadata.get('stored_path'),
            'md5_hash': metadata.get('md5_hash'),
            'project_id': project_id,
            'memory_id': metadata.get('memory_id')
        }
        
        return await self.db.create_file(file_data)
    
    async def _publish_event(self, event_type: str, metadata: Dict):
        event = {
            'event_type': event_type,
            'file_id': metadata.get('id'),
            'filename': metadata.get('filename'),
            'payload': metadata
        }
        
        await self.kafka.send('file_events', key=metadata.get('id'), value=event)
    
    def _get_mime_type(self, ext: str) -> str:
        mime_types = {
            '.mp4': 'video/mp4', '.mkv': 'video/x-matroska',
            '.mp3': 'audio/mpeg', '.wav': 'audio/wav',
            '.pdf': 'application/pdf',
            '.jpg': 'image/jpeg', '.jpeg': 'image/jpeg', '.png': 'image/png'
        }
        return mime_types.get(ext.lower(), 'application/octet-stream')
