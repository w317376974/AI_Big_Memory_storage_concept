from typing import Dict, List, Optional
from datetime import datetime


class CrossValidator:
    """交叉验证器 - 验证记忆状态"""
    
    def __init__(self, db_client):
        self.db = db_client
    
    async def verify_memory(self, memory_id: str) -> Dict:
        """验证记忆状态
        
        流程:
        1. 获取记忆内容
        2. 查找关联的待办 (triggered)
        3. 查找验证关系 (verified)
        4. 判断验证状态
        """
        
        # 1. 获取记忆
        memory = await self.db.get_memory(memory_id)
        if not memory:
            return {'error': 'Memory not found'}
        
        # 2. 查找触发的待办
        triggered_todos = await self.db.query("""
            SELECT t.*, ml.context as trigger_context, ml.created_at as triggered_at
            FROM todos t
            JOIN memory_links ml ON ml.target_id = t.id AND ml.target_type = 'todo'
            WHERE ml.source_id = $1 
              AND ml.link_type = 'triggered'
              AND ml.source_type = 'memory'
        """, memory_id)
        
        # 3. 查找验证关系
        verifications = await self.db.query("""
            SELECT t.*, ml.context as verification_context, 
                   ml.created_at as verified_at
            FROM memory_links ml
            JOIN todos t ON ml.source_id = t.id AND ml.source_type = 'todo'
            WHERE ml.target_id = $1 
              AND ml.link_type = 'verified'
              AND ml.target_type = 'memory'
        """, memory_id)
        
        # 4. 判断验证状态
        verified_todos = [v for v in verifications if v['status'] == 'completed']
        pending_todos = [t for t in triggered_todos if t['status'] == 'pending']
        in_progress_todos = [t for t in triggered_todos if t['status'] == 'in_progress']
        
        if verified_todos:
            status = 'verified'
            latest_verification = verified_todos[0]
        elif in_progress_todos:
            status = 'in_progress'
            latest_verification = in_progress_todos[0]
        elif pending_todos:
            status = 'pending'
            latest_verification = None
        else:
            status = 'unverified'
            latest_verification = None
        
        return {
            'memory': {
                'id': memory['id'],
                'content': memory['content'],
                'source_date': memory['source_date'],
                'tags': memory.get('tags', [])
            },
            'status': status,
            'triggered_todos': triggered_todos,
            'verifications': verifications,
            'verified': len(verified_todos) > 0,
            'latest_verification': latest_verification,
            'summary': self._build_summary(status, memory, verified_todos)
        }
    
    def _build_summary(self, status: str, memory: Dict, verified_todos: List) -> str:
        """构建验证摘要"""
        
        if status == 'verified' and verified_todos:
            todo = verified_todos[0]
            return f"✅ 已验证: {todo.get('title')} (完成于 {todo.get('completed_at')})"
        elif status == 'in_progress':
            return f"🔄 进行中: {len(verified_todos)} 个待办正在处理"
        elif status == 'pending':
            return f"⏳ 待处理: 记忆有待办待执行"
        else:
            return "❓ 未验证: 暂无关联的待办"
    
    async def verify_by_query(self, query: str) -> Dict:
        """通过自然语言查询验证记忆
        
        用户问: "上次那个部署问题解决了吗?"
        """
        
        # 1. 搜索相关记忆
        memories = await self.db.search_memories(query, limit=5)
        
        if not memories:
            return {'error': '未找到相关记忆', 'query': query}
        
        # 2. 对每个记忆进行验证
        results = []
        for memory in memories:
            verification = await self.verify_memory(memory['id'])
            results.append(verification)
        
        # 3. 返回最相关的验证结果
        verified_results = [r for r in results if r.get('verified')]
        
        if verified_results:
            return verified_results[0]
        elif results:
            return results[0]
        
        return {'error': '验证失败'}
    
    async def auto_link_on_create(self, entity_type: str, entity_id: str, data: Dict):
        """创建实体时自动建立关联
        
        触发时机:
        - memory 创建时
        - todo 创建时
        - todo 状态变更时
        """
        
        if entity_type == 'memory':
            await self._link_memory_with_todos(entity_id, data)
            await self._link_memory_with_lessons(entity_id, data)
            await self._link_similar_memories(entity_id, data)
        
        elif entity_type == 'todo':
            if data.get('status') == 'completed':
                await self._create_verification_links(entity_id, data)
    
    async def _link_memory_with_todos(self, memory_id: str, memory_data: Dict):
        """记忆关联待办"""
        
        source_date = memory_data.get('source_date')
        if not source_date:
            return
        
        # 查找同日期待办
        todos = await self.db.find_todos(due_date=source_date)
        
        for todo in todos:
            # 检查关键词重叠
            memory_keywords = set(memory_data.get('content', '').split())
            todo_keywords = set(todo.get('title', '').split())
            
            overlap = memory_keywords & todo_keywords
            
            if overlap:
                await self.db.create_link(
                    source_id=memory_id,
                    source_type='memory',
                    target_id=todo['id'],
                    target_type='todo',
                    link_type='triggered',
                    strength=min(0.3 + 0.1 * len(overlap), 1.0),
                    context=f"关键词重叠: {', '.join(overlap)}"
                )
    
    async def _link_memory_with_lessons(self, memory_id: str, memory_data: Dict):
        """记忆关联经验教训"""
        
        memory_tags = set(memory_data.get('tags', []))
        
        # 查找相关标签的经验教训
        lessons = await self.db.find_lessons_by_tags(list(memory_tags))
        
        for lesson in lessons:
            # 计算关联强度
            lesson_tags = set(lesson.get('tags', []))
            overlap = memory_tags & lesson_tags
            
            if overlap:
                await self.db.create_link(
                    source_id=memory_id,
                    source_type='memory',
                    target_id=lesson['id'],
                    target_type='lesson',
                    link_type='related',
                    strength=len(overlap) / max(len(memory_tags | lesson_tags), 1),
                    context=f"标签重叠: {', '.join(overlap)}"
                )
    
    async def _link_similar_memories(self, memory_id: str, memory_data: Dict):
        """关联相似记忆"""
        
        # 使用向量相似度查找相似记忆
        similar = await self.db.find_similar_memories(
            memory_id=memory_id,
            threshold=0.7,
            limit=5
        )
        
        for sim in similar:
            await self.db.create_link(
                source_id=memory_id,
                source_type='memory',
                target_id=sim['id'],
                target_type='memory',
                link_type='related',
                strength=sim['similarity'],
                context="语义相似"
            )
    
    async def _create_verification_links(self, todo_id: str, todo_data: Dict):
        """待办完成时创建验证链接"""
        
        source_memory_ids = todo_data.get('source_memory_ids', [])
        
        for memory_id in source_memory_ids:
            # 检查是否已存在验证链接
            existing = await self.db.query("""
                SELECT id FROM memory_links
                WHERE source_id = $1 AND source_type = 'todo'
                  AND target_id = $2 AND target_type = 'memory'
                  AND link_type = 'verified'
            """, todo_id, memory_id)
            
            if not existing:
                await self.db.create_link(
                    source_id=todo_id,
                    source_type='todo',
                    target_id=memory_id,
                    target_type='memory',
                    link_type='verified',
                    strength=1.0,
                    context=f"待办完成验证: {todo_data.get('title')}"
                )
        
        # 同时验证相关的记忆
        related_memory_ids = todo_data.get('related_memory_ids', [])
        
        for memory_id in related_memory_ids:
            if memory_id not in source_memory_ids:
                await self.db.create_link(
                    source_id=todo_id,
                    source_type='todo',
                    target_id=memory_id,
                    target_type='memory',
                    link_type='verified',
                    strength=0.8,
                    context=f"相关待办验证: {todo_data.get('title')}"
                )
