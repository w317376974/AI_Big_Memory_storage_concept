# 数值解析规则

SIZE_PATTERNS = {
    r'(\d+(?:\.\d+)?)\s*TB': lambda x: x * 1024**4,
    r'(\d+(?:\.\d+)?)\s*GB': lambda x: x * 1024**3,
    r'(\d+(?:\.\d+)?)\s*MB': lambda x: x * 1024**2,
    r'(\d+(?:\.\d+)?)\s*KB': lambda x: x * 1024,
    r'(\d+(?:\.\d+)?)\s*B': lambda x: x,
}

DURATION_PATTERNS = {
    r'(\d+)\s*小时': lambda h: h * 3600,
    r'(\d+)\s*h': lambda h: h * 3600,
    r'(\d+)\s*分钟': lambda m: m * 60,
    r'(\d+)\s*min': lambda m: m * 60,
    r'(\d+)\s*秒': lambda s: s,
    r'(\d+)\s*s': lambda s: s,
    r'(\d+):(\d+):(\d+)': lambda h, m, s: h*3600 + m*60 + s,  # HH:MM:SS
    r'(\d+):(\d+)': lambda m, s: m*60 + s,  # MM:SS
}

# 解析函数
def parse_file_size(text: str) -> Optional[int]:
    """解析文件大小描述"""
    for pattern, converter in SIZE_PATTERNS.items():
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            value = float(match.group(1))
            return int(converter(value))
    return None

def parse_duration(text: str) -> Optional[float]:
    """解析时长描述"""
    for pattern, converter in DURATION_PATTERNS.items():
        match = re.search(pattern, text, re.IGNORECASE)
        if match:
            args = [float(g) for g in match.groups()]
            return converter(*args)
    return None

# 使用示例
parse_file_size("8GB")        # → 8589934592
parse_file_size("10.5MB")     # → 11010048
parse_duration("2小时26分")   # → 8760.0
parse_duration("1:30:45")     # → 5445.0


