3.2.3 关系图谱召回 (Neo4j)
// 路径: 记忆 -> 待办 -> 项目 -> 相关记忆
MATCH (m:Memory {content: '三体'})
OPTIONAL MATCH (m)-[:RELATED]->(m2:Memory)
OPTIONAL MATCH (m)-[:TRIGGERED]->(t:Todo)
OPTIONAL MATCH (t)-[:BELONGS_TO]->(p:Project)
OPTIONAL MATCH (p)-[:HAS]->(m3:Memory)
RETURN m, m2, t, p, m3
LIMIT 30

// 查找与"三体"相关的所有实体 (记忆 + 文件 + 经验)
MATCH (n)-[r]-(m:Memory)
WHERE m.content CONTAINS '三体' OR m.tags CONTAINS '三体'
RETURN n, r, labels(n) as entity_type
LIMIT 50

// 扩展关联: 找到相关文件的记忆
MATCH (f:File)-[:LINKED]-(m:Memory)
WHERE m.content CONTAINS '三体'
RETURN f, m
ORDER BY f.file_size DESC
3.2.4 元数据精确过滤
-- 条件组合查询
SELECT 
    id, filename, file_size, mime_type, format,
    resolution, duration, user_description, user_tags,
    ST_X(location::geometry) as lon, 
    ST_Y(location::geometry) as lat,
    created_at
FROM file_metadata 
WHERE 
    -- 大小范围 (8GB左右，允许±20%误差)
    (file_size BETWEEN 7000000000 AND 9000000000 OR file_size IS NULL)
    -- 格式匹配
    AND (format IN ('mp4', 'mkv', 'avi', 'mov') OR mime_type LIKE 'video/%')
    -- 用户描述/标签命中
    AND (
        user_description ILIKE '%三体%' 
        OR filename ILIKE '%三体%' 
        OR user_tags && ARRAY['三体', '电影']
    )
    -- 地理位置过滤 (可选)
    AND (location IS NULL OR ST_DWithin(location, ST_MakePoint(116.4, 39.9)::geography, 50000))
ORDER BY file_size DESC, created_at DESC
LIMIT 20;
3.3 融合排序算法
3.3.1 融合公式
# 融合公式
def fusion_rank(results_list, query_context):
    """
    results_list: [[result_a, result_b, ...], ...]  # 多路召回结果
    query_context: {
        session_memory_ids,  # 当前会话相关记忆
        active_project,       # 活跃项目
        time_range,          # 时间范围
        user_preferences     # 用户偏好
    }
    """
    
    # ============ Step 1: 去重合并 ============
    merged = {}
    for channel_results in results_list:
        for item in channel_results:
            if item.id not in merged:
                merged[item.id] = {
                    'item': item,
                    'scores': {},
                    'channels': [],
                    'metadata_hits': 0
                }
            merged[item.id]['scores'][item.channel] = item.score
            merged[item.id]['channels'].append(item.channel)
            
            # 统计元数据命中
            if item.metadata_matches:
                merged[item.id]['metadata_hits'] += len(item.metadata_matches)
    
    # ============ Step 2: 权重融合 ============
    channel_weights = {
        'semantic': 0.35,    # 语义向量
        'keyword': 0.30,     # 关键词
        'graph': 0.20,       # 关系图谱
        'metadata': 0.15     # 元数据精确匹配
    }
    
    final_results = []
    for id, data in merged.items():
        item = data['item']
        
        # 基础融合分数
        fused_score = 0
        for ch, weight in channel_weights.items():
            score = data['scores'].get(ch, 0)
            fused_score += score * weight
        
        # ============ Step 3: 上下文增强 ============
        
        # 3.1 当前会话相关加权
        if item.id in query_context.session_memory_ids:
            fused_score *= 1.3
        
        # 3.2 活跃项目关联加权
        if item.project_id == query_context.active_project:
            fused_score *= 1.25
        
        # 3.3 多通道命中加权
        channel_count = len(data['channels'])
        if channel_count >= 3:
            fused_score *= 1.2
        elif channel_count == 2:
            fused_score *= 1.1
        
        # 3.4 元数据命中加权
        if data['metadata_hits'] > 0:
            fused_score *= (1 + 0.1 * min(data['metadata_hits'], 3))
        
        # ============ Step 4: 时间衰减 ============
        days_old = (now - item.created_at).days
        if days_old <= 7:
            time_factor = 1.2
        elif days_old <= 30:
            time_factor = 1.1
        elif days_old <= 90:
            time_factor = 1.0
        elif days_old <= 365:
            time_factor = max(0.7, 1 - (days_old - 90) / 500)
        else:
            time_factor = 0.5
        
        fused_score *= time_factor
        
        # ============ Step 5: 用户偏好调整 ============
        if query_context.user_preferences:
            # 例如用户偏好视频，文件类型加权
            if item.type == 'file' and item.format in query_context.user_preferences.get('preferred_formats', []):
                fused_score *= 1.15
        
        item.final_score = fused_score
        item.channels_hit = data['channels']
        final_results.append(item)
    
    # ============ Step 6: 排序返回 ============
    return sorted(final_results, key=lambda x: x.final_score, reverse=True)
