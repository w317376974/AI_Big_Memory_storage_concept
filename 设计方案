2. 数据模型设计
2.1 核心表结构
2.1.1 记忆原子表 (memory_atoms)
CREATE TABLE memory_atoms (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    atom_type       ATOM_TYPE_ENUM NOT NULL,  -- raw_daily, refined_weekly, lesson, project_doc
    content         TEXT NOT NULL,             -- 原始/提炼内容
    embedding       vector(1536),              -- 语义向量 (text-embedding-3-small)
    
    -- 层级关系
    source_date     DATE,                      -- 原始日期 (raw_daily用)
    refined_period  VARCHAR(20),               -- 提炼周期: weekly/monthly
    refined_from    UUID[],                    -- 原始记忆ID列表
    
    -- 元数据
    metadata        JSONB,                     -- 动态元数据
    tags            TEXT[],
    importance      FLOAT DEFAULT 0.5,         -- 重要性 0-1
    
    created_at      TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);

-- 向量索引 (HNSW)
CREATE INDEX idx_atoms_embedding ON memory_atoms USING hnsw (embedding vector_cosine_ops);
CREATE INDEX idx_atoms_type ON memory_atoms(atom_type);
CREATE INDEX idx_atoms_date ON memory_atoms(source_date);
2.1.2 关联关系表 (memory_links)
CREATE TABLE memory_links (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    source_id       UUID REFERENCES memory_atoms(id),
    target_id       UUID REFERENCES memory_atoms(id),
    
    link_type       LINK_TYPE_ENUM NOT NULL,   -- derived(提炼), related(相关), 
                                                -- verified(验证), part_of(属于), 
                                                -- blocks(阻塞/冲突), references(引用)
    strength        FLOAT DEFAULT 0.5,         -- 关联强度 0-1
    
    -- 验证关系专用
    verification_status VARCHAR(20),           -- pending, confirmed, rejected
    verified_by_todo_id UUID,                  -- 通过哪个Todo验证
    
    context         TEXT,                      -- 关联上下文说明
    created_at      TIMESTAMP DEFAULT NOW(),
    
    UNIQUE(source_id, target_id, link_type)
);

-- 图索引
CREATE INDEX idx_links_source ON memory_links(source_id);
CREATE INDEX idx_links_target ON memory_links(target_id);
CREATE INDEX idx_links_type ON memory_links(link_type);
2.1.3 待办表 (todos)
CREATE TABLE todos (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title           TEXT NOT NULL,
    description     TEXT,
    
    status          TODO_STATUS_ENUM DEFAULT 'pending',  -- pending, in_progress, completed, cancelled
    priority        PRIORITY_ENUM DEFAULT 'medium',      -- low, medium, high, urgent
    
    due_date        DATE,
    completed_at    TIMESTAMP,
    
    -- 关键: 与记忆的双向关联
    source_memory_ids   UUID[],        -- 触发此待办的记忆ID
    related_memory_ids  UUID[],        -- 相关的记忆ID (交叉验证用)
    
    project_id      UUID,              -- 关联项目
    
    created_at      TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);

-- 索引
CREATE INDEX idx_todos_status ON todos(status);
CREATE INDEX idx_todos_due ON todos(due_date);
CREATE INDEX idx_todos_memory ON todos USING GIN(source_memory_ids);
2.1.4 项目表 (projects)
CREATE TABLE projects (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    name            TEXT NOT NULL,
    description     TEXT,
    code_repo       TEXT,               -- 代码仓库URL
    status          PROJECT_STATUS DEFAULT 'active',
    
    -- 项目关联的记忆集合
    memory_ids      UUID[],
    todo_ids        UUID[],
    lesson_ids      UUID[],             -- 关联的经验教训
    
    created_at      TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);
2.1.5 经验教训表 (lessons)
CREATE TABLE lessons (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    title           TEXT NOT NULL,
    content         TEXT NOT NULL,      -- 简短描述 (建议 < 200字)
    
    category        VARCHAR(50),        -- tool_usage, deployment, bug_fix, workflow, decision
    tags            TEXT[],
    
    -- 关键: 关联溯源
    source_memory_ids   UUID[],        -- 来源记忆
    source_todo_ids     UUID[],        -- 来源待办
    source_project_ids  UUID[],        -- 来源项目
    
    -- 复用统计
    reference_count    INT DEFAULT 0,  -- 被引用次数
    last_referenced_at TIMESTAMP,
    
    created_at      TIMESTAMP DEFAULT NOW()
);

CREATE INDEX idx_lessons_category ON lessons(category);
CREATE INDEX idx_lessons_tags ON lessons USING GIN(tags);
2.1.6 文件元数据表 (file_metadata) ⚠️ 重点
CREATE TABLE file_metadata (
    id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    
    -- 基础信息
    filename        TEXT NOT NULL,
    original_path   TEXT,
    stored_path     TEXT,               -- MinIO key
    file_size       BIGINT,             -- 字节
    mime_type       TEXT,
    format          VARCHAR(20),        -- mp4, mkv, pdf, zip...
    
    -- 媒体属性 (音视频)
    duration        FLOAT,              -- 秒
    resolution      VARCHAR(20),        -- 1920x1080
    bitrate         BIGINT,
    codec           VARCHAR(50),
    
    -- 语义向量 (文件内容/帧)
    embedding       vector(1536),       -- 视频关键帧 / 音频embedding
    
    -- 自动提取的元数据
    auto_summary    TEXT,               -- LLM生成的摘要
    transcript      TEXT,               -- 字幕/ transcript
    user_description TEXT,              -- 用户原始描述 "三体电影"
    user_tags       TEXT[],
    
    -- 地理空间元数据
    location        GEOGRAPHY(POINT),   -- GPS坐标
    location_name   TEXT,               -- 地名 "北京朝阳区"
    
    -- 指纹 (去重)
    md5_hash        VARCHAR(32),
    perceptual_hash VARCHAR(32),        -- 感知哈希 (近似重复检测)
    
    -- 关联
    memory_ids      UUID[],             -- 关联的记忆
    project_id      UUID,
    
    created_at      TIMESTAMP DEFAULT NOW(),
    updated_at      TIMESTAMP DEFAULT NOW()
);

-- 索引
CREATE INDEX idx_file_embedding ON file_metadata USING hnsw (embedding vector_cosine_ops);
CREATE INDEX idx_file_size ON file_metadata(file_size);
CREATE INDEX idx_file_location ON file_metadata USING GIST(location);
CREATE INDEX idx_file_tags ON file_metadata USING GIN(user_tags);
CREATE INDEX idx_file_hash ON file_metadata(md5_hash);
3.2 召回通道详解
3.2.1 语义向量召回 (pgvector)
-- 基础语义搜索
SELECT id, content, 1 - (embedding <=> $query_embedding) as similarity
FROM memory_atoms 
WHERE atom_type IN ('raw_daily', 'refined_weekly', 'project_doc')
ORDER BY embedding <=> $query_embedding
LIMIT 50;

-- 文件语义搜索 (针对 "三体电影")
SELECT id, filename, auto_summary, file_size, resolution,
       1 - (embedding <=> $query_embedding) as similarity
FROM file_metadata
WHERE file_size > 0
ORDER BY embedding <=> $query_embedding
LIMIT 30;

-- 带时间权重的语义搜索
SELECT id, content, source_date,
       1 - (embedding <=> $query_embedding) as similarity,
       CASE 
           WHEN source_date >= CURRENT_DATE - INTERVAL '7 days' THEN 1.3
           WHEN source_date >= CURRENT_DATE - INTERVAL '30 days' THEN 1.1
           WHEN source_date >= CURRENT_DATE - INTERVAL '90 days' THEN 1.0
           ELSE 0.8
       END as time_weight
FROM memory_atoms
ORDER BY (similarity * time_weight) DESC
LIMIT 50;
