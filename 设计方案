class MemoryEventConsumer:
    async def consume(self):
        consumer = KafkaConsumer(
            'memory_events',
            bootstrap_servers=['localhost:9092'],
            group_id='es_indexer',
            value_deserializer=lambda m: json.loads(m.decode('utf-8'))
        )
        
        async for message in consumer:
            event = message.value
            
            if event['event_type'] == 'created':
                await self._index_to_elasticsearch(event['payload'])
                await self._sync_to_neo4j(event['payload'])
                await self._cache_to_redis(event['payload'])
                
            elif event['event_type'] == 'updated':
                await self._reindex_elasticsearch(event['atom_id'])
                await self._update_neo4j(event['payload'])
                
            elif event['event_type'] == 'deleted':
                await self._delete_from_elasticsearch(event['atom_id'])
                await self._delete_from_neo4j(event['atom_id'])
    
    async def _index_to_elasticsearch(self, payload):
        """索引到 ES"""
        await es_client.index(
            index='memories',
            id=payload['atom_id'],
            document={
                'content': payload['content'],
                'tags': payload.get('tags', []),
                'atom_type': payload['atom_type'],
                'source_date': payload.get('source_date'),
                'metadata': payload.get('metadata', {}),
                'embedding': payload.get('embedding')
            }
        )
    
    async def _sync_to_neo4j(self, payload):
        """同步到 Neo4j"""
        await neo4j_client.execute(
            """
            CREATE (m:Memory {
                id: $id,
                content: $content,
                atom_type: $atom_type,
                created_at: $created_at
            })
            """,
            id=payload['atom_id'],
            content=payload['content'],
            atom_type=payload['atom_type'],
            created_at=payload.get('created_at', datetime.now())
        )
7.4 消息顺序与幂等性
# 消息顺序保证
class OrderedConsumer:
    """
    同 ID 的消息必须按顺序处理
    使用单分区 + 按 key 哈希保证顺序
    """
    
    async def consume(self):
        # 按 atom_id 分区，保证同一记忆的消息有序
        consumer = KafkaConsumer(
            'memory_events',
            bootstrap_servers=['localhost:9092'],
            group_id='ordered_processor',
            partition_assignment_strategy=RoundRobinPartitionAssignor
        )
        
        # 本地消息排序缓冲区
        pending = {}  # {atom_id: [messages...]}
        
        async for message in consumer:
            event = message.value
            key = event.get('atom_id') or event.get('file_id')
            
            if key not in pending:
                pending[key] = []
            pending[key].append(event)
            
            # 按时间戳排序后处理
            pending[key].sort(key=lambda x: x['timestamp'])
            
            # 处理最早的消息
            if self._is_ready_to_process(pending[key]):
                await self._process(pending[key].pop(0))
    
    def _is_ready_to_process(self, messages):
        """检查是否可以处理"""
        if not messages:
            return False
        # 只有第一条消息没有前置依赖时才处理
        return True

# 幂等性处理
class IdempotentProcessor:
    """使用事件 ID 去重"""
    
    def __init__(self):
        self.processed = RedisSet('processed_events:ttl:86400')
    
    async def process(self, event):
        event_id = event['event_id']
        
        # 检查是否已处理
        if await self.processed.exists(event_id):
            logger.info(f"跳过重复事件: {event_id}")
            return
        
        # 处理业务逻辑
        await self._do_process(event)
        
        # 标记已处理
        await self.processed.add(event_id)
