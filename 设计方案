class GeocodingService:
    """地理编码服务 - 地名转坐标"""
    
    def __init__(self, api_key: str, provider: str = "amap"):
        self.api_key = api_key
        self.provider = provider  # amap/baidu
    
    async def geocode(self, location_name: str) -> Optional[dict]:
        """地名转坐标"""
        
        if not location_name:
            return None
        
        if self.provider == "amap":
            return await self._amap_geocode(location_name)
        elif self.provider == "baidu":
            return await self._baidu_geocode(location_name)
        else:
            raise ValueError(f"Unknown provider: {self.provider}")
    
    async def _amap_geocode(self, location_name: str) -> Optional[dict]:
        """高德地图地理编码"""
        
        url = "https://restapi.amap.com/v3/geocode/geo"
        params = {
            "key": self.api_key,
            "address": location_name,
            "output": "JSON"
        }
        
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params) as resp:
                data = await resp.json()
                
                if data.get("status") == "1" and data.get("geocodes"):
                    geo = data["geocodes"][0]
                    location = geo["location"].split(",")
                    
                    return {
                        "lon": float(location[0]),
                        "lat": float(location[1]),
                        "province": geo.get("province", ""),
                        "city": geo.get("city", ""),
                        "district": geo.get("district", ""),
                        "adcode": geo.get("adcode", ""),
                        "formatted_address": geo.get("formatted_address", "")
                    }
        
        return None
    
    async def _baidu_geocode(self, location_name: str) -> Optional[dict]:
        """百度地图地理编码"""
        
        url = "http://api.map.baidu.com/geocoding/v3/"
        params = {
            "address": location_name,
            "output": "json",
            "ak": self.api_key
        }
        
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params) as resp:
                data = await resp.json()
                
                if data.get("status") == 0:
                    loc = data["result"]["location"]
                    comp = data["result"]["addressComponent"]
                    
                    return {
                        "lon": loc["lng"],
                        "lat": loc["lat"],
                        "province": comp.get("province", ""),
                        "city": comp.get("city", ""),
                        "district": comp.get("district", ""),
                        "adcode": comp.get("adcode", ""),
                        "formatted_address": data["result"].get("formatted_address", "")
                    }
        
        return None
    
    def to_postgis(self, lat: float, lon: float) -> str:
        """转换为 PostGIS geography 类型的 WKT"""
        return f"ST_SetSRID(ST_MakePoint({lon}, {lat}), 4326)::geography"
    
    def to_geojson(self, lat: float, lon: float) -> dict:
        """转换为 GeoJSON Point"""
        return {
            "type": "Point",
            "coordinates": [lon, lat]
        }


class ReverseGeocodingService:
    """逆地理编码 - 坐标转地名"""
    
    def __init__(self, api_key: str, provider: str = "amap"):
        self.api_key = api_key
        self.provider = provider
    
    async def reverse(self, lat: float, lon: float) -> Optional[dict]:
        """坐标转地名"""
        
        if self.provider == "amap":
            return await self._amap_reverse(lat, lon)
        elif self.provider == "baidu":
            return await self._baidu_reverse(lat, lon)
        
        return None
    
    async def _amap_reverse(self, lat: float, lon: float) -> Optional[dict]:
        """高德逆地理编码"""
        
        url = "https://restapi.amap.com/v3/geocode/regeo"
        params = {
            "key": self.api_key,
            "location": f"{lon},{lat}",  # 高德: 经度,纬度
            "output": "JSON",
            "radius": "1000"  # 半径(米)
        }
        
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params) as resp:
                data = await resp.json()
                
                if data.get("status") == "1":
                    regeo = data.get("regeocode", {})
                    address = regeo.get("addressComponent", {})
                    
                    return {
                        "formatted_address": regeo.get("formatted_address", ""),
                        "province": address.get("province", ""),
                        "city": address.get("city", ""),
                        "district": address.get("district", ""),
                        "township": address.get("township", ""),
                        "street": address.get("streetNumber", {}).get("street", ""),
                        "number": address.get("streetNumber", {}).get("number", "")
                    }
        
        return None


